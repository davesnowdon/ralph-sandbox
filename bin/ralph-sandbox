#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
SANDBOX_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"
COMPOSE_FILE="${SANDBOX_ROOT}/docker-compose.yml"

usage() {
  cat <<'EOF'
Usage:
  bin/ralph-sandbox [options] [-- ralph_args...]

Options:
  --project-dir PATH        Use an existing project directory. Defaults to the current git root or cwd.
  --tool NAME               Tool to use: claude or codex. Defaults to $RALPH_TOOL or claude.
  --session-runner PATH     Custom runner script to replace the built-in Ralph loop.
  --claude-config-dir PATH  Claude config directory. Defaults to $CLAUDE_CONFIG_DIR or $HOME/.claude.
  --codex-config-dir PATH   Codex config directory. Defaults to $CODEX_CONFIG_DIR or $HOME/.codex.
  --service NAME            Compose service to run. Defaults to ralph.
  --build                   Pass --build to docker compose run.
  -h, --help                Show this help.

Examples:
  bin/ralph-sandbox
  bin/ralph-sandbox --tool codex
  bin/ralph-sandbox --session-runner ./my-runner.sh --project-dir /path/to/project
  bin/ralph-sandbox -- 10
EOF
}

abs_existing_dir() {
  local path="$1"
  if [[ ! -d "${path}" ]]; then
    echo "ERROR: Directory does not exist: ${path}" >&2
    exit 2
  fi
  cd -- "${path}" && pwd -P
}

git_repo_root() {
  local path="$1"
  git -C "${path}" rev-parse --show-toplevel 2>/dev/null || true
}

git_common_dir() {
  local path="$1"
  local common
  common="$(git -C "${path}" rev-parse --git-common-dir 2>/dev/null || true)"
  if [[ -z "${common}" ]]; then
    return 0
  fi
  if [[ "${common}" = /* ]]; then
    printf '%s\n' "${common}"
    return 0
  fi
  cd -- "${path}" && cd -- "${common}" && pwd -P
}

project_dir="${PROJECT_DIR:-}"
ralph_tool="${RALPH_TOOL:-claude}"
claude_config_dir="${CLAUDE_CONFIG_DIR:-${HOME}/.claude}"
codex_config_dir="${CODEX_CONFIG_DIR:-${HOME}/.codex}"
session_runner=""
service="ralph"
build_flag=0
declare -a ralph_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project-dir)
      project_dir="$2"
      shift 2
      ;;
    --tool)
      ralph_tool="$2"
      shift 2
      ;;
    --session-runner)
      session_runner="$2"
      shift 2
      ;;
    --claude-config-dir)
      claude_config_dir="$2"
      shift 2
      ;;
    --codex-config-dir)
      codex_config_dir="$2"
      shift 2
      ;;
    --service)
      service="$2"
      shift 2
      ;;
    --build)
      build_flag=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      ralph_args=("$@")
      break
      ;;
    *)
      ralph_args+=("$1")
      shift
      ;;
  esac
done

if [[ -z "${project_dir}" ]]; then
  project_dir="$(git_repo_root "${PWD}")"
  if [[ -z "${project_dir}" ]]; then
    project_dir="$(pwd -P)"
  fi
fi

project_dir="$(abs_existing_dir "${project_dir}")"

# Resolve session runner to an absolute path (if provided).
if [[ -n "${session_runner}" ]]; then
  if [[ ! -f "${session_runner}" ]]; then
    echo "ERROR: --session-runner path does not exist: ${session_runner}" >&2
    exit 2
  fi
  session_runner="$(cd "$(dirname "${session_runner}")" && pwd -P)/$(basename "${session_runner}")"
fi

# Tool config validation is only needed when using the default runner.
if [[ -z "${session_runner}" ]]; then
  case "${ralph_tool}" in
    claude)
      claude_config_dir="$(abs_existing_dir "${claude_config_dir}")"
      ;;
    codex)
      if ! mkdir -p "${codex_config_dir}"; then
        echo "ERROR: Failed to create codex config directory: ${codex_config_dir}" >&2
        exit 2
      fi
      codex_config_dir="$(abs_existing_dir "${codex_config_dir}")"
      ;;
    *)
      echo "ERROR: Unsupported tool: ${ralph_tool}. Use 'claude' or 'codex'." >&2
      exit 2
      ;;
  esac
fi

common_dir="$(git_common_dir "${project_dir}")"
needs_common_mount=0
if [[ -n "${common_dir}" && "${common_dir}" != "${project_dir}/.git" ]]; then
  common_dir="$(abs_existing_dir "${common_dir}")"
  needs_common_mount=1
fi

tmp_override="$(mktemp "${TMPDIR:-/tmp}/ralph-sandbox.compose.override.XXXXXX.yml")"
cleanup() {
  rm -f -- "${tmp_override}"
}
trap cleanup EXIT

cat >"${tmp_override}" <<EOF
services:
  ${service}:
EOF

# Collect extra volume mounts (tool config, git common dir, session runner).
if [[ ${needs_common_mount} -eq 1 ]] || [[ "${ralph_tool}" == "claude" ]] || [[ "${ralph_tool}" == "codex" ]] || [[ -n "${session_runner}" ]]; then
  echo "    volumes:" >>"${tmp_override}"
fi

if [[ "${ralph_tool}" == "claude" ]]; then
  cat >>"${tmp_override}" <<EOF
      - type: bind
        source: '${claude_config_dir}'
        target: /claude_config
EOF
fi

if [[ ${needs_common_mount} -eq 1 ]]; then
  cat >>"${tmp_override}" <<EOF
      - type: bind
        source: '${common_dir}'
        target: '${common_dir}'
EOF
fi

if [[ "${ralph_tool}" == "codex" ]]; then
  cat >>"${tmp_override}" <<EOF
      - type: bind
        source: '${codex_config_dir}'
        target: /codex_config
EOF
fi

if [[ -n "${session_runner}" ]]; then
  cat >>"${tmp_override}" <<EOF
      - type: bind
        source: '${session_runner}'
        target: /run/ralph/session-runner.sh
        read_only: true
EOF
fi

declare -a compose_cmd=(
  docker compose
  --project-directory "${SANDBOX_ROOT}"
  -f "${COMPOSE_FILE}"
  -f "${tmp_override}"
  run
  --rm
)

if [[ ${build_flag} -eq 1 ]]; then
  compose_cmd+=(--build)
fi

compose_cmd+=("${service}")

session_runner_env=""
if [[ -n "${session_runner}" ]]; then
  session_runner_env="/run/ralph/session-runner.sh"
fi

declare -a config_env=()
case "${ralph_tool}" in
  claude)
    config_env+=(CLAUDE_CONFIG_DIR="${claude_config_dir}")
    ;;
  codex)
    config_env+=(CODEX_CONFIG_DIR="${codex_config_dir}")
    ;;
esac

env \
  PROJECT_DIR="${project_dir}" \
  RALPH_TOOL="${ralph_tool}" \
  SESSION_RUNNER="${session_runner_env}" \
  "${config_env[@]}" \
  "${compose_cmd[@]}" \
  "${ralph_args[@]}"
